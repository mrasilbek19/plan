            <span><%=user.skills[2]%></span> 
            <span>80%</span>
        </div>
        <div class="percentage">
            <svg xmlns="http://www.w3.org/2000/svg" width="220" height="5" viewBox="0 0 221 5" fill="none">
<rect x="0.25" y="0.25" width="220.5" height="4.5" rx="2.25" stroke="#FFB400" stroke-width="0.5"/>
<rect x="1.5" y="1.5" width="209" height="2" rx="1" fill="#FFB400"/>
</svg>
        </div>
                        </div>
                        <div class="skill_item">
                             <div class="paragraph_letters">
            <span><%=user.skills[3]%></span> 
            <span>80%</span>
        </div>
        <div class="percentage">
            <svg xmlns="http://www.w3.org/2000/svg" width="220" height="5" viewBox="0 0 221 5" fill="none">
<rect x="0.25" y="0.25" width="220.5" height="4.5" rx="2.25" stroke="#FFB400" stroke-width="0.5"/>
<rect x="1.5" y="1.5" width="209" height="2" rx="1" fill="#FFB400"/>
</svg>
        </div>
                        </div>
                        <div class="skill_item">
                             <div class="paragraph_letters">
            <span><%=user.skills[4]%></span> 
            <span>80%</span>
        </div>
        <div class="percentage">
            <svg xmlns="http://www.w3.org/2000/svg" width="220" height="5" viewBox="0 0 221 5" fill="none">
<rect x="0.25" y="0.25" width="220.5" height="4.5" rx="2.25" stroke="#FFB400" stroke-width="0.5"/>
<rect x="1.5" y="1.5" width="209" height="2" rx="1" fill="#FFB400"/>
</svg>
        </div>
                        </div>
                    
                </div>

                <div class="marginer"></div>

                <!-- EXTRA SKILLS -->
                <div class="extra_skills">
                     <div class="themes">Extra skills</div>
                     <div class="extra_item">
                        <div class="paragraph_letters">
                            <span>
                               <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
<rect x="0.5" y="0.5" width="9" height="9" stroke="#FFB400"/>
<rect x="5.5" y="5.5" width="9" height="9" stroke="#FFB400"/>
</svg> 
                            </span> <span>hello</span></div>
                     </div>
                </div>
                  
                <div class="marginer"></div>

            </div>

            <!-- MIDDLE FRAME -->
            <div class="mid_frame">

                <div class="mid_top"></div>

                <div class="mid_buttom">

                    <div class="mini_groups">
                        <div class="mid_buttom-icons"></div>
                        <div class="mid_buttom-text1"></div>
                        <div class="mid_buttom-text2"></div>
                    </div>

                    <div class="mini_groups">
